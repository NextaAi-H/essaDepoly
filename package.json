{
  "name": "hse-pilot",
  "version": "0.1.0",
  "private": true,
  "description": "AI-based HSE report scanning & compliance review system (pilot MVP)",
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix web",
    "seed": "npm run seed --prefix server",
    "dev:server": "npm run dev --prefix server",
    "dev:web": "npm run dev --prefix web",
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "build": "npm run build --prefix web",
    "start": "npm run start --prefix server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
